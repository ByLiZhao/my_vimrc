		" the following may not work depending on the terminal emulator used.
		" even if "echo &term" prints "xterm", it is may not xterm compatible.
		let &t_SI.="\e[5 q" "SI = INSERT mode
		let &t_SR.="\e[4 q" "SR = REPLACE mode
		let &t_EI.="\e[1 q" "EI = NORMAL mode (ELSE)
		"  1 -> blinking block
		"  2 -> solid block
		"  3 -> blinking underscore
		"  4 -> solid underscore
		"  5 -> blinking vertical bar
		"  6 -> solid vertical bar
