" define the following for cpp, c projects
nnoremap <leader>h <Esc>:Rooter<CR>:call CurtineIncSw()<CR>
" Press F4 to compile current buffer
autocmd  FileType cpp nnoremap <silent> <F4> :AsyncRun -cwd=$(VIM_FILEDIR) g++ -Wall -Wextra -std=c++20
						\ -pthread -O2  -g
						\ -I. -I src -I include -I.. -I../include -I../src -I../sp
						\ "$(VIM_FILEPATH)" -o  "$(VIM_FILEDIR)/$(VIM_FILENOEXT)" <cr>

autocmd  FileType cpp nnoremap <silent> <leader>c :AsyncRun -cwd=$(VIM_FILEDIR) g++ -Wall -Wextra -std=c++20
                        \ -S -fverbose-asm
						\ -pthread -O2
						\ -I. -I src -I include -I.. -I../include -I ../src -I../sp
						\ "$(VIM_FILEPATH)"  <cr>

autocmd  FileType c nnoremap <silent> <F4> :AsyncRun -cwd=$(VIM_FILEDIR) gcc -Wall -Wextra
						\ -pthread -O2
						\ -I. -I src -I include -I.. -I../include -I../src
						\ "$(VIM_FILEPATH)" -o  "$(VIM_FILEDIR)/$(VIM_FILENOEXT)" <cr>

autocmd FileType c nnoremap <silent> <leader>c :AsyncRun -cwd=$(VIM_FILEDIR) gcc -Wall -Wextra
                        \ -S -fverbose-asm
						\ -pthread -O2
						\ -I. -I src -I include -I.. -I../include -I../src
						\ "$(VIM_FILEPATH)"  <cr>

" press F9 to remove files generated by F4 and <leader>\.
autocmd FileType cpp noremap <silent> <F9> :AsyncRun rm -f "$(VIM_FILEDIR)/$(VIM_FILENOEXT).s" "$(VIM_FILEDIR)/$(VIM_FILENOEXT)" <cr>
autocmd FileType c noremap <silent> <F9> :AsyncRun rm -f "$(VIM_FILEDIR)/$(VIM_FILENOEXT).s" "$(VIM_FILEDIR)/$(VIM_FILENOEXT)" <cr>

" Press F5 run the executable from current file
autocmd  FileType cpp nnoremap <silent> <F5> :AsyncRun -mode=term -pos=right -raw -cwd=$(VIM_FILEDIR) "$(VIM_FILEDIR)/$(VIM_FILENOEXT)" <cr>
autocmd  FileType c nnoremap <silent> <F5> :AsyncRun -mode=term -pos=right -raw -cwd=$(VIM_FILEDIR) "$(VIM_FILEDIR)/$(VIM_FILENOEXT)" <cr>

" Press F6 to Looks up the symbol under the cursor and jumps to its declaration.
" Supported in filetypes: c, cpp, objc, objcpp, cuda, cs, go, java, javascript, python, rust, typescript
autocmd  FileType cpp nnoremap <silent> <F6> :YcmCompleter GoToDeclaration <cr>
autocmd  FileType c nnoremap <silent> <F6> :YcmCompleter GoToDeclaration <cr>
autocmd  FileType cuda nnoremap <silent> <F6> :YcmCompleter GoToDeclaration <cr>

" Press F7 to kooks up the symbol under the cursor and jumps to its definition
" Supported in filetypes: c, cpp, objc, objcpp, cuda, cs, go, java, javascript, python, rust, typescript
" For C-family languages, only works when the definition is in current TU.
autocmd  FileType cpp nnoremap <silent> <F7> :YcmCompleter GoToDefinition <cr>
autocmd  FileType c nnoremap <silent> <F7> :YcmCompleter GoToDefinition <cr>
autocmd  FileType cuda nnoremap <silent> <F7> :YcmCompleter GoToDefinition <cr>

" Press F8 jump to a header, or definition, or declaration.
autocmd FileType cpp nnoremap <silent> <F8> :YcmCompleter GoTo<CR>
autocmd FileType c nnoremap <silent> <F8> :YcmCompleter GoTo<CR>

